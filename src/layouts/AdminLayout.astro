---
import '../styles/global.css';

export interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>{title}</title>
	
	<!-- Fonts -->
	<link rel="preconnect" href="https://fonts.googleapis.com">
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
	<link href="https://fonts.googleapis.com/css2?family=Cormorant:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Raleway:wght@200;300;400;500;600&display=swap" rel="stylesheet">
	
	<!-- FontAwesome -->
	<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
	
	<!-- Favicon -->
	<link rel="icon" type="image/png" href="/favicon.png?v=3">
    
    <style is:global>
        body {
            background-color: #040A14;
            background-image: radial-gradient(circle at 50% 0%, rgba(201,169,110,0.05) 0%, transparent 50%);
            background-attachment: fixed;
            color: var(--cream);
            font-family: var(--font-body);
            opacity: 0; /* Hide until auth check completes */
            transition: opacity 0.3s ease;
            min-height: 100vh;
        }
        .admin-nav {
            background: rgba(6, 16, 32, 0.8);
            backdrop-filter: blur(10px);
            padding: 15px 40px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid rgba(255,255,255,0.05);
            position: sticky;
            top: 0;
            z-index: 100;
        }
        .admin-nav img {
            height: 30px;
        }
        .admin-main {
            max-width: 1000px;
            margin: 60px auto;
            padding: 0 40px;
        }
        .admin-table {
            width: 100%;
            border-collapse: separate;
            border-spacing: 0;
            margin-top: 10px;
        }
        .admin-table th, .admin-table td {
            padding: 20px;
            text-align: center;
            border-bottom: 1px solid rgba(255,255,255,0.03);
        }
        .admin-table th:first-child, .admin-table td:first-child { text-align: left; }
        .admin-table th:last-child, .admin-table td:last-child { text-align: right; }
        
        .admin-table th {
            color: var(--gold);
            font-family: var(--font-heading);
            font-size: 16px;
            text-transform: uppercase;
            letter-spacing: 2px;
            border-bottom: 1px solid rgba(201,169,110,0.2);
        }
        .admin-table tbody tr {
            transition: background 0.3s ease;
        }
        .admin-table tbody tr:hover {
            background: rgba(255,255,255,0.02);
        }
        .admin-card {
            background: rgba(255, 255, 255, 0.02);
            backdrop-filter: blur(20px);
            padding: 40px;
            border: 1px solid rgba(255, 255, 255, 0.05);
            border-radius: 16px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.2);
        }
        .action-btn {
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.1);
            color: var(--cream);
            cursor: pointer;
            margin-left: 8px;
            transition: all 0.3s ease;
            width: 36px;
            height: 36px;
            border-radius: 50%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }
        .action-btn:hover {
            background: var(--gold);
            color: var(--navy);
            border-color: var(--gold);
            transform: translateY(-2px);
        }
        .action-btn.delete:hover {
            background: #ff4d4d;
            border-color: #ff4d4d;
            color: white;
        }
    </style>
</head>
<body>
    <nav class="admin-nav" id="admin-navbar" style="display:none;">
        <a href="/admin"><img src="/logo.png" alt="AWE YACHTS Admin"></a>
        <div>
            <span id="admin-user-email" style="margin-right: 20px; opacity: 0.7;"></span>
            <button onclick="handleLogout()" class="btn-outline" style="padding: 8px 16px; font-size: 12px;">Logout</button>
        </div>
    </nav>
	<slot />
    
    <script>
        import { supabase } from '../lib/supabase';
        window.supabase = supabase; // Expose for legacy scripts in other pages

        // Global Auth Check
        window.addEventListener('DOMContentLoaded', async () => {
            const isLoginPage = window.location.pathname.includes('/admin/login');
            
            const { data: { session } } = await supabase.auth.getSession();
            
            if (!session && !isLoginPage) {
                window.location.href = '/admin/login';
            } else if (session && isLoginPage) {
                window.location.href = '/admin';
            } else {
                document.body.style.opacity = '1';
                if (session) {
                    const nav = document.getElementById('admin-navbar');
                    if(nav) nav.style.display = 'flex';
                    const emailEl = document.getElementById('admin-user-email');
                    if(emailEl) emailEl.textContent = session.user.email;
                }
            }
        });

        window.handleLogout = async () => {
            await window.supabase.auth.signOut();
            window.location.href = '/admin/login';
        };
    </script>
</body>
</html>
