---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

export interface Props {
	title: string;
	description?: string;
	image?: string;
	lang?: 'en' | 'es' | 'de';
}

const { 
	title, 
	description = "AWE YACHTS offers an exclusive selection of luxury yachts for sale and charter across the Mediterranean and worldwide. Experience, discretion and elegance.",
	image = "/hero-bg.webp",
	lang = 'en'
} = Astro.props;

// Construct full absolute URL for OpenGraph images and links
const canonicalURL = new URL(Astro.url.pathname, Astro.site || Astro.url.origin).href;
const socialImageURL = new URL(image, Astro.site || Astro.url.origin).href;
---

<!DOCTYPE html>
<html lang={lang}>
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>{title}</title>
	<meta name="description" content={description}>
	<meta name="google-site-verification" content="vzOfbUedQkbp1eqtX47ZT5anrX9Okd93MGUu83xoKN8" />
	
	<!-- i18n / SEO Hreflang Tags -->
	<link rel="alternate" hreflang="en" href={`${new URL('/', Astro.site || Astro.url.origin).href}`} />
	<link rel="alternate" hreflang="es" href={`${new URL('/es/', Astro.site || Astro.url.origin).href}`} />
	<link rel="alternate" hreflang="de" href={`${new URL('/de/', Astro.site || Astro.url.origin).href}`} />
	<link rel="alternate" hreflang="x-default" href={`${new URL('/', Astro.site || Astro.url.origin).href}`} />
	
	<!-- OpenGraph / Facebook -->
	<meta property="og:type" content="website">
	<meta property="og:url" content={canonicalURL}>
	<meta property="og:title" content={title}>
	<meta property="og:description" content={description}>
	<meta property="og:image" content={socialImageURL}>

	<!-- Twitter -->
	<meta property="twitter:card" content="summary_large_image">
	<meta property="twitter:url" content={canonicalURL}>
	<meta property="twitter:title" content={title}>
	<meta property="twitter:description" content={description}>
	<meta property="twitter:image" content={socialImageURL}>
	<!-- Fonts -->
	<link rel="preconnect" href="https://fonts.googleapis.com">
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
	<link href="https://fonts.googleapis.com/css2?family=Cormorant:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Raleway:wght@200;300;400;500&display=swap" rel="stylesheet">
	
	<!-- FontAwesome -->
	<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
	
	<!-- Favicon -->
	<link rel="icon" type="image/png" href="/favicon.png?v=3">

	<!-- Google tag (gtag.js) -->
	<script async src="https://www.googletagmanager.com/gtag/js?id=G-FKBH6L4R00"></script>
	<script is:inline>
	  window.dataLayer = window.dataLayer || [];
	  function gtag(){dataLayer.push(arguments);}
	  gtag('js', new Date());

	  gtag('config', 'G-FKBH6L4R00');
	</script>
</head>
<body>
	<Navbar lang={lang} />
	<slot />
	<Footer lang={lang} />
	
	<!-- WhatsApp Floating Button -->
	<a href="https://wa.me/34614582862" class="whatsapp-float" target="_blank" rel="noopener noreferrer" aria-label="Contact us on WhatsApp">
		<i class="fab fa-whatsapp"></i>
	</a>
	
	{/* Language Auto-Detection Script (Only runs on root '/') */}
	{Astro.url.pathname === '/' && (
		<script>
			if (!localStorage.getItem('langSelected')) {
				const userLang = navigator.language.slice(0, 2);
				if (userLang === 'es') {
					window.location.replace('/es/');
				} else if (userLang === 'de') {
					window.location.replace('/de/');
				}
			}
		</script>
	)}
	
	<script>
		// Reveal animations
		const reveals = document.querySelectorAll('.reveal');
		const observer = new IntersectionObserver((entries) => {
			entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); observer.unobserve(e.target); } });
		}, { threshold: 0.12 });
		reveals.forEach(el => observer.observe(el));
	</script>
</body>
</html>
