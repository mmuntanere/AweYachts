---
import AdminLayout from '../../../layouts/AdminLayout.astro';
---

<AdminLayout title="AWE YACHTS — New Yacht">
  <div class="admin-main">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
      <h1 class="hero-title" style="font-size: 32px; margin: 0;">Add <em>New Yacht</em></h1>
      <a href="/admin" class="btn-outline" style="padding: 10px 20px;">Back to Fleet</a>
    </div>

    <div class="admin-card">
      <form id="yacht-form" onsubmit="handleSave(event)">
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px;">
          <div class="form-group">
            <label>ID (URL Slug) <small style="color:var(--text-muted); font-weight:normal;">- Auto-generated</small></label>
            <input type="text" id="yacht-id" required readonly style="background: rgba(0,0,0,0.2); cursor: not-allowed; color: var(--text-muted);">
          </div>
          <div class="form-group">
            <label>Name</label>
            <input type="text" id="yacht-name" required>
          </div>
          <div class="form-group">
            <label>Model (e.g. Sunseeker 65)</label>
            <input type="text" id="yacht-type" required>
          </div>
          <div class="form-group">
            <label>Price (e.g. € 8,500,000)</label>
            <input type="text" id="yacht-price">
          </div>
          <div class="form-group">
            <label>Length Overall (LOA) (e.g. 45m (147'))</label>
            <input type="text" id="yacht-length">
          </div>
          <div class="form-group">
            <label>Guests</label>
            <input type="text" id="yacht-guests">
          </div>
          <div class="form-group">
            <label>Crew</label>
            <input type="text" id="yacht-crew">
          </div>
          <div class="form-group">
            <label>Year (e.g. 2021)</label>
            <input type="text" id="yacht-year">
          </div>
        </div>

        <div class="form-group">
          <label>Description</label>
          <textarea id="yacht-description" rows="10"></textarea>
        </div>

        <div class="form-group">
          <label>Main Image Upload</label>
          <input type="file" id="yacht-image-file" accept="image/*">
          <p style="font-size:12px; color:var(--text-muted); margin-top:5px;">If you select a file, it will be uploaded to Supabase Storage and used as the main image.</p>
        </div>

        <div class="form-group">
          <label>Gallery Images Upload</label>
          <input type="file" id="yacht-gallery-files" accept="image/*" multiple>
          <p style="font-size:12px; color:var(--text-muted); margin-top:5px;">Select multiple files for the yacht's gallery.</p>
        </div>

        <button type="submit" class="btn-primary" id="save-btn" style="width: 100%; margin-top: 20px;">Save Yacht</button>
      </form>
    </div>
  </div>

  <script>
    // Auto-generate URL Slug from Name
    document.getElementById('yacht-name')?.addEventListener('input', (e) => {
      const name = (e.target as HTMLInputElement).value;
      const slug = name.toLowerCase().trim()
        .replace(/[^a-z0-9]+/g, '-')
        .replace(/(^-|-$)+/g, '');
      (document.getElementById('yacht-id') as HTMLInputElement).value = slug;
    });

    // Auto-format Price
    document.getElementById('yacht-price')?.addEventListener('input', (e) => {
      let val = (e.target as HTMLInputElement).value.replace(/[^0-9]/g, '');
      if (!val) {
        (e.target as HTMLInputElement).value = '';
        return;
      }
      (e.target as HTMLInputElement).value = '€ ' + parseInt(val, 10).toLocaleString('en-US');
    });

    window.handleSave = async (e) => {
      e.preventDefault();
      const btn = document.getElementById('save-btn');
      btn.textContent = 'Saving...';
      btn.disabled = true;

      const id = document.getElementById('yacht-id').value;
      const fileInput = document.getElementById('yacht-image-file');
      let main_image = 'yacht-placeholder.png'; // default fallback

      // 1. Upload Image if selected
      if (fileInput.files.length > 0) {
        const file = fileInput.files[0];
        const fileExt = file.name.split('.').pop();
        const fileName = `${id}-${Math.random()}.${fileExt}`;
        const filePath = `${fileName}`;

        const { error: uploadError } = await window.supabase.storage
          .from('yacht-images')
          .upload(filePath, file);

        if (uploadError) {
          alert('Error uploading image: ' + uploadError.message);
          btn.textContent = 'Save Yacht';
          btn.disabled = false;
          return;
        }

        // Get public URL
        const { data: { publicUrl } } = window.supabase.storage
          .from('yacht-images')
          .getPublicUrl(filePath);
        
        main_image = publicUrl;
      }

      // 2. Upload Gallery Images
      const galleryInput = document.getElementById('yacht-gallery-files');
      let gallery = [];
      if (galleryInput.files.length > 0) {
        btn.textContent = 'Uploading gallery...';
        for (let i = 0; i < galleryInput.files.length; i++) {
          const file = galleryInput.files[i];
          const fileExt = file.name.split('.').pop();
          const fileName = `${id}-gal-${Date.now()}-${i}.${fileExt}`;
          
          const { error: galError } = await window.supabase.storage
            .from('yacht-images')
            .upload(fileName, file);
            
          if (!galError) {
            const { data: { publicUrl } } = window.supabase.storage
              .from('yacht-images')
              .getPublicUrl(fileName);
            gallery.push(publicUrl);
          }
        }
      }

      // 3. Insert into Database
      const record = {
        id,
        name: document.getElementById('yacht-name').value,
        type: document.getElementById('yacht-type').value,
        price: document.getElementById('yacht-price').value,
        length: document.getElementById('yacht-length').value,
        guests: document.getElementById('yacht-guests').value,
        crew_cabins: document.getElementById('yacht-crew').value,
        year: document.getElementById('yacht-year').value,
        description: document.getElementById('yacht-description').value,
        main_image,
        gallery
      };

      const { error } = await window.supabase.from('yachts').insert([record]);

      if (error) {
        alert('Error saving yacht: ' + error.message);
        btn.textContent = 'Save Yacht';
        btn.disabled = false;
      } else {
        alert('Yacht successfully added!');
        window.location.href = '/admin';
      }
    };
  </script>
</AdminLayout>
