---
import AdminLayout from '../../../layouts/AdminLayout.astro';
---

<AdminLayout title="AWE YACHTS — Edit Yacht">
  <div class="admin-main">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px;">
      <h1 class="hero-title" style="font-size: 32px; margin: 0;">Edit <em>Yacht</em></h1>
      <a href="/admin" class="btn-outline" style="padding: 10px 20px;">Back to Fleet</a>
    </div>

    <div class="admin-card" id="edit-loading">
      <p style="text-align: center;">Loading yacht data...</p>
    </div>

    <div class="admin-card" id="edit-form-container" style="display: none;">
      <form id="yacht-form" onsubmit="handleUpdate(event)">
        <input type="hidden" id="yacht-original-id">
        <input type="hidden" id="yacht-original-image">
        
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px;">
          <div class="form-group">
            <label>ID (Read-only)</label>
            <input type="text" id="yacht-id" disabled>
          </div>
          <div class="form-group">
            <label>Name</label>
            <input type="text" id="yacht-name" required>
          </div>
          <div class="form-group">
            <label>Model</label>
            <input type="text" id="yacht-type" required>
          </div>
          <div class="form-group">
            <label>Price</label>
            <input type="text" id="yacht-price">
          </div>
          <div class="form-group">
            <label>Length Overall (LOA) (e.g. 45m (147'))</label>
            <input type="text" id="yacht-length">
          </div>
          <div class="form-group">
            <label>Guests</label>
            <input type="text" id="yacht-guests">
          </div>
          <div class="form-group">
            <label>Crew</label>
            <input type="text" id="yacht-crew">
          </div>
        </div>

        <div class="form-group">
          <label>Description</label>
          <textarea id="yacht-description" rows="10"></textarea>
        </div>

        <div class="form-group">
          <label>Update Main Image</label>
          <div style="margin-bottom: 10px;">
            <img id="current-image-preview" src="" style="width: 150px; border-radius: 4px; display: none;">
          </div>
          <input type="file" id="yacht-image-file" accept="image/*">
          <p style="font-size:12px; color:var(--text-muted); margin-top:5px;">Leave empty to keep the current image.</p>
        </div>

        <div class="form-group" style="border-top: 1px solid rgba(255,255,255,0.1); margin-top: 20px; padding-top: 20px;">
          <label>Manage Gallery</label>
          <div id="gallery-preview-container" style="margin-bottom: 10px; display: flex; flex-wrap: wrap; gap: 10px;">
            <!-- Current gallery images will be injected here -->
          </div>
          <label style="font-size: 14px; margin-top: 10px;">Add New Gallery Images</label>
          <input type="file" id="yacht-gallery-files" accept="image/*" multiple>
          <p style="font-size:12px; color:var(--text-muted); margin-top:5px;">Select multiple files to add to the existing gallery.</p>
        </div>

        <button type="submit" class="btn-primary" id="save-btn" style="width: 100%; margin-top: 20px;">Update Yacht</button>
      </form>
    </div>
  </div>

  <script>
    window.addEventListener('DOMContentLoaded', async () => {
      await new Promise(r => setTimeout(r, 200)); // wait for auth

      const urlParams = new URLSearchParams(window.location.search);
      const id = urlParams.get('id');

      if(!id) {
        alert('No yacht ID provided.');
        window.location.href = '/admin';
        return;
      }

      const { data, error } = await window.supabase.from('yachts').select('*').eq('id', id).single();

      if(error || !data) {
        document.getElementById('edit-loading').innerHTML = '<p style="color:#ff4d4d;text-align:center;">Error loading yacht or not found.</p>';
        return;
      }

      // Populate form
      document.getElementById('yacht-original-id').value = data.id;
      document.getElementById('yacht-original-image').value = data.main_image || '';
      
      document.getElementById('yacht-id').value = data.id;
      document.getElementById('yacht-name').value = data.name;
      document.getElementById('yacht-type').value = data.type;
      document.getElementById('yacht-price').value = data.price;
      document.getElementById('yacht-length').value = data.length || '';
      document.getElementById('yacht-guests').value = data.guests || '';
      document.getElementById('yacht-crew').value = data.crew_cabins || '';
      document.getElementById('yacht-year').value = data.year || '';

      document.getElementById('yacht-description').value = data.description || '';

      if(data.main_image) {
        const preview = document.getElementById('current-image-preview');
        // Handle absolute URL from Supabase vs legacy local filename
        preview.src = data.main_image.startsWith('http') ? data.main_image : `/${data.main_image}`;
        preview.style.display = 'block';
      }

      window.currentGallery = data.gallery || [];
      window.renderGallery();

      document.getElementById('edit-loading').style.display = 'none';
      document.getElementById('edit-form-container').style.display = 'block';
    });

    window.renderGallery = () => {
      const container = document.getElementById('gallery-preview-container');
      if (window.currentGallery.length === 0) {
        container.innerHTML = '<p style="font-size:13px; color:var(--text-muted);">No gallery images.</p>';
        return;
      }
      container.innerHTML = window.currentGallery.map((img, index) => {
        const src = img.startsWith('http') ? img : `/${img}`;
        return `<div style="position:relative; display:inline-block;">
          <img src="${src}" style="width:100px; height:75px; object-fit:cover; border-radius:4px; border: 1px solid rgba(255,255,255,0.1);">
          <button type="button" onclick="removeGalleryImage(${index})" style="position:absolute; top:-8px; right:-8px; background:#ff4d4d; color:white; border:none; border-radius:50%; width:24px; height:24px; cursor:pointer; font-weight:bold; display:flex; align-items:center; justify-content:center; box-shadow: 0 2px 5px rgba(0,0,0,0.5);">&times;</button>
        </div>`;
      }).join('');
    };

    window.removeGalleryImage = (index) => {
      window.currentGallery.splice(index, 1);
      window.renderGallery();
    };

      // Auto-format Price
      document.getElementById('yacht-price')?.addEventListener('input', (e) => {
        let val = e.target.value.replace(/[^0-9]/g, '');
        if (!val) {
          e.target.value = '';
          return;
        }
        e.target.value = '€ ' + parseInt(val, 10).toLocaleString('en-US');
      });

    window.handleUpdate = async (e) => {
      e.preventDefault();
      const btn = document.getElementById('save-btn');
      btn.textContent = 'Updating...';
      btn.disabled = true;

      const id = document.getElementById('yacht-original-id').value;
      const fileInput = document.getElementById('yacht-image-file');
      let mainImage = document.getElementById('yacht-original-image').value;

      // Upload new Image if selected
      if (fileInput.files.length > 0) {
        const file = fileInput.files[0];
        const fileExt = file.name.split('.').pop();
        const fileName = `${id}-${Math.random()}.${fileExt}`;
        
        const { error: uploadError } = await window.supabase.storage
          .from('yacht-images')
          .upload(fileName, file);

        if (uploadError) {
          alert('Error uploading new image: ' + uploadError.message);
          btn.textContent = 'Update Yacht';
          btn.disabled = false;
          return;
        }

        const { data: { publicUrl } } = window.supabase.storage
          .from('yacht-images')
          .getPublicUrl(fileName);
        
        mainImage = publicUrl;
      }

      // Upload new Gallery Images
      const galleryInput = document.getElementById('yacht-gallery-files');
      let newGallery = [...window.currentGallery];
      if (galleryInput.files.length > 0) {
        btn.textContent = 'Uploading gallery...';
        for (let i = 0; i < galleryInput.files.length; i++) {
          const file = galleryInput.files[i];
          const fileExt = file.name.split('.').pop();
          const fileName = `${id}-gal-${Date.now()}-${i}.${fileExt}`;
          
          const { error: galError } = await window.supabase.storage
            .from('yacht-images')
            .upload(fileName, file);
            
          if (!galError) {
            const { data: { publicUrl } } = window.supabase.storage
              .from('yacht-images')
              .getPublicUrl(fileName);
            newGallery.push(publicUrl);
          }
        }
      }

      // Update Database
      const payload = {
        name: document.getElementById('yacht-name').value,
        type: document.getElementById('yacht-type').value,
        price: document.getElementById('yacht-price').value,
        length: document.getElementById('yacht-length').value,
        guests: document.getElementById('yacht-guests').value,
        crew_cabins: document.getElementById('yacht-crew').value,
        year: document.getElementById('yacht-year').value,
        description: document.getElementById('yacht-description').value,
        main_image: mainImage,
        gallery: newGallery
      };

      const { error } = await window.supabase.from('yachts').update(payload).eq('id', id);

      if (error) {
        alert('Error updating yacht: ' + error.message);
        btn.textContent = 'Update Yacht';
        btn.disabled = false;
      } else {
        alert('Yacht successfully updated!');
        window.location.href = '/admin';
      }
    };
  </script>
</AdminLayout>
