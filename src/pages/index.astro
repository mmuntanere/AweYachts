---
import Layout from '../layouts/Layout.astro';
import YachtCard from '../components/YachtCard.astro';
import ContactForm from '../components/ContactForm.astro';
import { supabase } from '../lib/supabase';

// Fetch from Supabase
const { data: yachtsArray, error } = await supabase.from('yachts').select('*').neq('is_deleted', true);
if (error) console.error("Error fetching yachts", error);
---

<Layout title="AWE YACHTS — Luxury Yacht Brokerage">
  <!-- HERO -->
  <section class="hero" id="home" aria-label="Hero section">
    <div class="hero-video-wrap" aria-hidden="true">
      <img src="/hero-bg.png" alt="Luxury superyacht at Mediterranean marina" style="width: 100%; height: 100%; object-fit: cover;">
    </div>
    <div class="hero-overlay" aria-hidden="true"></div>
    <div class="hero-content">
      <div class="hero-badge">Luxury Yacht Brokerage</div>
      <h1 class="hero-title">Define your <em>horizon</em></h1>
      <p class="hero-subtitle">Limitless Experiences.</p>
      <div class="hero-actions">
        <a href="#yachts" class="btn-primary" id="explore-yachts-btn">Explore Yachts</a>
        <a href="#contact" class="btn-outline" id="hero-contact-btn">Speak with an Expert</a>
      </div>
    </div>
  </section>

  <!-- YACHTS -->
  <section class="yachts-section" id="yachts" aria-label="Featured yachts">
    <div class="yachts-header reveal">
      <div>
        <div class="section-tag">Exclusive Selection</div>
        <h2 class="section-title">Featured <em>Yachts</em></h2>
      </div>
    </div>

    <div class="yachts-grid" id="yachts-grid">
      {yachtsArray.map((yacht, index) => {
        // Calculate delay logic from legacy: 0, 1, 2 looping based on index
        const delay = index % 3;
        // Determine tags from legacy hardcoded html if needed, or default
        const tags = [];
        if(yacht.id === 'azure-dream') tags.push('featured');
        if(yacht.id === 'aquarius') tags.push('exclusive');
        if(yacht.id === 'velocite') tags.push('performance');

        return (
          <YachtCard 
            id={yacht.id}
            name={yacht.name}
            type={yacht.type}
            length={yacht.length} 
            guests={yacht.guests}
            crew={yacht.crew_cabins}
            year={yacht.year}
            price={yacht.price}
            image={yacht.main_image.startsWith('http') ? yacht.main_image : `/${yacht.main_image}`}
            tags={tags}
            delay={delay}
            widthStyle={yacht.width_style || 'normal'}
            imagePosition={yacht.image_position || 'center'}
          />
        );
      })}
    </div>


  </section>

  <!-- ABOUT -->
  <section class="about-section" id="about" aria-label="About AWE YACHTS">
    <div class="about-image-wrap">
      <img src="/about-bg.png" alt="AWE YACHTS luxury brokerage — Alex Bonet, Founder" loading="lazy">
      <div class="about-image-overlay" aria-hidden="true"></div>
    </div>
    <div class="about-content">
      <div class="section-tag reveal">Our Story</div>
      <h2 class="section-title reveal">Excellence is<br><em>our signature</em></h2>
      <p class="section-desc reveal">AWE YACHTS was born from a life lived on the water. Twenty-three years in the industry, eighteen of them skippering luxury yachts across the world's finest destinations. Backed by rigorous MYBA training and an intimate understanding of high-end project management, we don't just broker yachts — we live them.</p>
      <div class="about-features">
        <div class="about-feature reveal">
          <div class="about-feature-icon" aria-hidden="true"><i class="fas fa-shield-halved"></i></div>
          <div>
            <div class="about-feature-title">Total Discretion</div>
            <p class="about-feature-text">Every transaction is handled with the utmost confidentiality. Your privacy is our priority.</p>
          </div>
        </div>
        <div class="about-feature reveal reveal-delay-1">
          <div class="about-feature-icon" aria-hidden="true"><i class="fas fa-globe"></i></div>
          <div>
            <div class="about-feature-title">Global Network</div>
            <p class="about-feature-text">Global marketing presence with an exclusive network of high-calibre Buyers and Sellers.</p>
          </div>
        </div>
        <div class="about-feature reveal reveal-delay-2">
          <div class="about-feature-icon" aria-hidden="true"><i class="fas fa-compass"></i></div>
          <div>
            <div class="about-feature-title">Tailored Experience</div>
            <p class="about-feature-text">We focus entirely on your unique requirements, ensuring a seamless and personalised journey to find the perfect vessel.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- EXPERIENCE BANNER -->
  <div class="experience-banner" aria-label="Call to action">
    <div class="experience-banner-bg js-parallax" aria-hidden="true" style="height: 160%; top: -30%;">
      <video autoplay muted loop playsinline style="width: 100%; height: 100%; object-fit: cover; position: absolute; inset: 0;">
        <source src="/hero-video.mp4" type="video/mp4">
      </video>
      <img src="/banner-video-fallback.png" alt="Luxury yacht" style="width: 100%; height: 100%; object-fit: cover; position: absolute; inset: 0; z-index: -1;">
    </div>
    <div class="experience-banner-overlay" aria-hidden="true"></div>
    <div class="experience-banner-content">
      <div class="section-tag reveal" style="justify-content:center;">Premium Experience</div>
      <h2 class="section-title reveal">Your next yacht<br>is <em>waiting for you</em></h2>
      <p class="section-desc reveal">Contact us today and let our experts guide you. We'll help you find the perfect vessel for your needs and aspirations.</p>
      <a href="#contact" class="btn-primary reveal" id="banner-cta-btn">Begin Your Search</a>
    </div>
  </div>

  <!-- CONTACT -->
  <section class="contact-section" id="contact" aria-label="Contact us">
    <div class="contact-info">
      <div class="section-tag reveal">We're Here</div>
      <h2 class="section-title reveal">Let's talk about<br><em>your next yacht</em></h2>
      <p class="section-desc reveal">Our team of experts is available to answer all your enquiries with the utmost discretion and professionalism.</p>
      <div class="contact-details">
        <div class="contact-detail reveal">
          <div class="contact-detail-icon" aria-hidden="true"><i class="fas fa-phone"></i></div>
          <div>
            <div class="contact-detail-label">Call Us</div>
            <div class="contact-detail-value">+34 614 582 862</div>
          </div>
        </div>
        <div class="contact-detail reveal reveal-delay-1">
          <div class="contact-detail-icon" aria-hidden="true"><i class="fas fa-envelope"></i></div>
          <div>
            <div class="contact-detail-label">Email</div>
            <div class="contact-detail-value">alex@aweyachts.com</div>
          </div>
        </div>
        <div class="contact-detail reveal reveal-delay-2">
          <div class="contact-detail-icon" aria-hidden="true"><i class="fas fa-location-dot"></i></div>
          <div>
            <div class="contact-detail-label">Office</div>
            <div class="contact-detail-value">Carrer Joan Maria Thomàs, 4<br>Ponent, 07014 Palma<br>Illes Balears</div>
          </div>
        </div>
      </div>
    </div>
    <ContactForm />
  </section>

  <script>
    // Parallax logic
    const heroBg = document.querySelector('.hero-video-wrap') as HTMLElement;
    window.addEventListener('scroll', () => {
      if (window.scrollY < window.innerHeight && heroBg) {
        heroBg.style.transform = `translateY(${window.scrollY * 0.35}px)`;
      }
    }, { passive: true });
  </script>
</Layout>
