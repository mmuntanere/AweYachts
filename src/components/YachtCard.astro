---
export interface Props {
  id: string;
  name: string;
  type: string;
  length: string;
  guests: string;
  crew?: string;
  year?: number | string;
  price: string;
  image: string;
  tags?: string[];
  delay?: number;
}

const { id, name, type, length, guests, crew, year, price, image, tags = [], delay = 0 } = Astro.props;

// Compute badge display logic based on tags or type
let displayTag = type;
if (tags.includes('featured')) displayTag += ' · Featured';
if (tags.includes('exclusive')) displayTag += ' · Exclusive';
if (tags.includes('performance')) displayTag += ' · Performance';

const delayClass = delay === 1 ? 'reveal-delay-1' : delay === 2 ? 'reveal-delay-2' : '';
---

<div class={`yacht-card reveal ${delayClass}`} data-type={type.toLowerCase().replace(' yacht', '')}>
  <a href={`/yacht/${id}`} style="display:block; width:100%; height:100%;">
    <img src={image} alt={`${name} - ${length} ${type}`} loading="lazy">
    <div class="yacht-card-btn" aria-label="View details"><i class="fas fa-arrow-right"></i></div>
    <div class="yacht-card-overlay">
      <div class="yacht-tag">{displayTag}</div>
      <div class="yacht-name">{name}</div>
      <div class="yacht-specs">
        <span class="yacht-spec"><i class="fas fa-ruler-horizontal"></i> {length}</span>
        <span class="yacht-spec"><i class="fas fa-user-friends"></i> {guests}</span>
        {crew && <span class="yacht-spec"><i class="fas fa-users"></i> {crew}</span>}
      </div>
      <div class="yacht-price">{price}</div>
    </div>
  </a>
</div>
