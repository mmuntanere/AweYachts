---
import { getLangFromUrl, useTranslations, getRelativeLocaleUrl, defaultLang } from '../i18n/ui';

export interface Props {
  id: string;
  name: string;
  type: string;
  length: string;
  guests: string;
  crew?: string;
  year?: number | string;
  price: string;
  image: string;
  tags?: string[];
  delay?: number;
  widthStyle?: string;
  imagePosition?: string;
  lang?: keyof typeof ui;
}

const { id, name, type, length, guests, crew, year, price, image, tags = [], delay = 0, widthStyle = 'normal', imagePosition = 'center', lang = defaultLang } = Astro.props;

const t = useTranslations(lang);
const basePath = getRelativeLocaleUrl(lang);

// Compute badge display logic based on tags or type
let displayTag = type;
if (tags.includes('featured')) displayTag += ' · Featured';
if (tags.includes('exclusive')) displayTag += ' · Exclusive';
if (tags.includes('performance')) displayTag += ' · Performance';

const delayClass = delay === 1 ? 'reveal-delay-1' : delay === 2 ? 'reveal-delay-2' : '';
---

<div class={`yacht-card yacht-width-${widthStyle} reveal ${delayClass}`} data-type={type.toLowerCase().replace(' yacht', '')}>
  <a href={`${basePath}yacht/${id}`} style="display:block; width:100%; height:100%;">
    <img src={image} alt={`${name} - ${length} ${type}`} loading="lazy" decoding="async" style={`object-position: center ${imagePosition};`}>
    <div class="yacht-card-btn" aria-label="View details"><i class="fas fa-arrow-right"></i></div>
    <div class="yacht-card-overlay">
      <div class="yacht-tag">{displayTag}</div>
      <div class="yacht-name">{name}</div>

      <div class="yacht-price">{price}</div>
    </div>
  </a>
</div>
