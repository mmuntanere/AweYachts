---
import { getLangFromUrl, useTranslations, defaultLang } from '../i18n/ui';

const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);
---
<footer role="contentinfo">
  <div class="footer-top">
    <div class="footer-brand">
      <div class="nav-logo">
        <img src="/logo.png" alt="AWE YACHTS" class="footer-logo-img">
      </div>
      <p class="footer-desc">{t('footer.desc')}</p>
      <div class="footer-social">
        <a href="#" class="social-btn" aria-label="Instagram"><i class="fab fa-instagram"></i></a>
        <a href="#" class="social-btn" aria-label="LinkedIn"><i class="fab fa-linkedin-in"></i></a>
        <a href="#" class="social-btn" aria-label="Facebook"><i class="fab fa-facebook-f"></i></a>
        <a href="#" class="social-btn" aria-label="YouTube"><i class="fab fa-youtube"></i></a>
      </div>
    </div>

    <div class="footer-col">
      <h4>Yachts</h4>
      <ul>
        <li><a href="/#yachts">Motor Yachts</a></li>
        <li><a href="/#yachts">Sailing Yachts</a></li>
        <li><a href="/#yachts">Catamarans</a></li>
        <li><a href="/#yachts">Superyachts</a></li>
      </ul>
    </div>
    <div class="footer-col">
      <h4>Services</h4>
      <ul>
        <li><a href="/#services">Yacht Sales</a></li>
        <li><a href="/#services">Sell Your Yacht</a></li>
        <li><a href="/#services">Charter</a></li>
        <li><a href="/#services">Marine Finance</a></li>
      </ul>
    </div>
    <div class="footer-col">
      <h4>{t('footer.quicklinks')}</h4>
      <ul>
        <li><a href="/#about">{t('nav.about')}</a></li>
        <li><a href="/#contact">{t('nav.contact')}</a></li>
        <li><a href="/legal">{t('footer.legal')}</a></li>
        <li><a href="/privacy">{t('footer.privacy')}</a></li>
      </ul>
    </div>
  </div>
  <div class="footer-bottom">
    <p>© 2026 AWE YACHTS. {t('footer.rights')}</p>
    <p>Crafted with <i class="fas fa-heart" style="color:#C9A96E;margin:0 4px;"></i></p>
  </div>
</footer>
