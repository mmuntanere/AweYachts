---
---
<div class="contact-form-wrap">
  <div class="section-tag reveal">Get in Touch</div>
  <h2 class="reveal">Request <em style="font-family:'Cinzel',serif;font-style:normal;color:#C9A96E;">information</em></h2>
  <form id="contact-form" onsubmit="handleFormSubmit(event)" novalidate>
    <div class="form-row">
      <div class="form-group reveal">
        <label for="contact-name">Name</label>
        <input type="text" id="contact-name" name="name" placeholder="Your name" required autocomplete="given-name">
      </div>
      <div class="form-group reveal reveal-delay-1">
        <label for="contact-email">Email</label>
        <input type="email" id="contact-email" name="email" placeholder="your@email.com" required autocomplete="email">
      </div>
    </div>
    <div class="form-group reveal">
      <label for="contact-phone">Phone</label>
      <input type="tel" id="contact-phone" name="phone" placeholder="+34 XXX XXX XXX" autocomplete="tel">
    </div>
    <div class="form-group reveal">
      <label for="contact-interest">Interest</label>
      <select id="contact-interest" name="interest">
        <option value="">Select an option</option>
        <option value="buy">Buy a yacht</option>
        <option value="sell">Sell my yacht</option>
        <option value="charter">Luxury charter</option>
        <option value="info">General information</option>
      </select>
    </div>
    <div class="form-group reveal">
      <label for="contact-message">Message</label>
      <textarea id="contact-message" name="message" placeholder="Tell us what kind of yacht you're looking for..."></textarea>
    </div>
    <button type="submit" class="btn-primary reveal" id="contact-submit-btn" style="width:100%;">Send Enquiry</button>
  </form>
</div>

<script>
  // Expose to window for the inline onsubmit
  window.handleFormSubmit = async function(e) {
    e.preventDefault();
    const form = e.target;
    const btn = document.getElementById('contact-submit-btn');
    if(!btn) return;
    const originalText = btn.textContent;
    
    btn.textContent = 'Sending...';
    btn.style.opacity = '0.7';
    btn.disabled = true;

    try {
      const formData = new FormData(form);
      const response = await fetch('/send_mail.php', {
        method: 'POST',
        body: formData
      });

      if (response.ok) {
        btn.textContent = '✓ Enquiry Sent';
        btn.style.background = '#1a3a1a';
        btn.style.color = '#6fcf97';
        btn.style.border = '1px solid #6fcf97';
        form.reset();
      } else {
        throw new Error('Network response was not ok.');
      }
    } catch (error) {
      btn.textContent = 'X Error Sending';
      btn.style.background = '#4a1a1a';
      btn.style.color = '#cf6f6f';
    }

    setTimeout(() => {
      btn.textContent = originalText;
      btn.style.background = '';
      btn.style.color = '';
      btn.style.border = '';
      btn.style.opacity = '1';
      btn.disabled = false;
    }, 4000);
  }
</script>
