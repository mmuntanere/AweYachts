---
import { useTranslations, defaultLang } from '../i18n/ui';
const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);
---
<div class="contact-form-wrap">
  <div class="section-tag reveal">{t('contact.get_in_touch')}</div>
  <h2 class="reveal">{t('contact.request_info_part1')} <em style="font-family:'Cinzel',serif;font-style:normal;color:#C9A96E;">{t('contact.request_info_part2')}</em></h2>
  <form id="contact-form" onsubmit="handleFormSubmit(event)" novalidate>
    <div class="form-row">
      <div class="form-group reveal">
        <label for="contact-name">{t('contact.form.name')}</label>
        <input type="text" id="contact-name" name="name" placeholder={t('contact.form.name.placeholder')} required autocomplete="given-name">
      </div>
      <div class="form-group reveal reveal-delay-1">
        <label for="contact-email">{t('contact.form.email')}</label>
        <input type="email" id="contact-email" name="email" placeholder={t('contact.form.email.placeholder')} required autocomplete="email">
      </div>
    </div>
    <div class="form-group reveal">
      <label for="contact-phone">{t('contact.form.phone')}</label>
      <input type="tel" id="contact-phone" name="phone" placeholder="+34 XXX XXX XXX" autocomplete="tel">
    </div>
    <div class="form-group reveal">
      <label for="contact-interest">{t('contact.form.interest')}</label>
      <select id="contact-interest" name="interest">
        <option value="">{t('contact.form.interest.select')}</option>
        <option value="buy">{t('contact.form.interest.buy')}</option>
        <option value="sell">{t('contact.form.interest.sell')}</option>
        <option value="charter">{t('contact.form.interest.charter')}</option>
        <option value="info">{t('contact.form.interest.info')}</option>
      </select>
    </div>
    <div class="form-group reveal">
      <label for="contact-message">{t('contact.form.message')}</label>
      <textarea id="contact-message" name="message" placeholder={t('contact.form.message.placeholder')}></textarea>
    </div>
    <button type="submit" class="btn-primary reveal" id="contact-submit-btn" style="width:100%;">{t('contact.form.submit')}</button>
  </form>
</div>

<script>
  // Expose to window for the inline onsubmit
  window.handleFormSubmit = async function(e) {
    e.preventDefault();
    const form = e.target;
    const btn = document.getElementById('contact-submit-btn');
    if(!btn) return;
    const originalText = btn.textContent;
    
    btn.textContent = 'Sending...';
    btn.style.opacity = '0.7';
    btn.disabled = true;

    try {
      const formData = new FormData(form);
      const response = await fetch('/send_mail.php', {
        method: 'POST',
        body: formData
      });

      if (response.ok) {
        btn.textContent = '✓ Enquiry Sent';
        btn.style.background = '#1a3a1a';
        btn.style.color = '#6fcf97';
        btn.style.border = '1px solid #6fcf97';
        form.reset();
      } else {
        throw new Error('Network response was not ok.');
      }
    } catch (error) {
      btn.textContent = 'X Error Sending';
      btn.style.background = '#4a1a1a';
      btn.style.color = '#cf6f6f';
    }

    setTimeout(() => {
      btn.textContent = originalText;
      btn.style.background = '';
      btn.style.color = '';
      btn.style.border = '';
      btn.style.opacity = '1';
      btn.disabled = false;
    }, 4000);
  }
</script>
